    "test": "turbo run test",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
