{
  "name": "codesesh",
  "version": "0.1.1",
  "description": "One place to see every AI coding session you've ever had. Unify Claude Code, Cursor, Kimi, Codex, and OpenCode sessions in a single, beautiful Web UI.",
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "kimi",
    "codex",
    "opencode",
    "session",
    "history",
    "visualization",
    "developer-tools",
    "cli",
    "web-ui"
  ],
  "homepage": "https://codesesh.xingkaixin.me/",
  "bugs": {
    "url": "https://github.com/xingkaixin/codesesh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xingkaixin/codesesh.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Kevin <xingkaixin@gmail.com>",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "codesesh": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-web-dist.js",
    "release": "tsup && node scripts/copy-web-dist.js",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@codesesh/core": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "hono": "^4.7.4",
    "open": "^10.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  }
}
